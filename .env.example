# ── API Keys (required for summarize/ask/external commands) ──
VIDUNDER_GEMINI_API_KEY=
VIDUNDER_OPENROUTER_KEY=
VIDUNDER_DOUBAO_API_KEY=
VIDUNDER_STEP_API_KEY=
VIDUNDER_DEEPSEEK_API_KEY=
VIDUNDER_MIMO_API_KEY=

# ── Video Input ──
VIDUNDER_VIDEO_PATH=/data/video.mp4
VIDUNDER_SRT_PATH=/data/video.sentence.srt

# ── LLM Inference ──
VIDUNDER_N_CTX=4096
VIDUNDER_N_GPU_LAYERS=36
VIDUNDER_GLM_OCR_N_GPU_LAYERS=17
VIDUNDER_N_BATCH=512
VIDUNDER_KV_CACHE_TYPE=q4_0
VIDUNDER_ONNX_PROVIDER=cuda

# ── Summarization ──
VIDUNDER_THINKING_BUDGET=low
VIDUNDER_SUMMARY_SLIDES_PER_CHAPTER=3
VIDUNDER_SUMMARY_LANG=中文
